{
  "tests": [
    {
      "name": "Short password rejected",
      "method": "POST",
      "path": "/?action=register",
      "body": {"login": "newtest99", "password": "short"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Пароль должен быть минимум 8 символов"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with correct credentials",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "testadmin", "password": "secret12345"},
      "expectedStatus": 200,
      "expectedBody": {"login": "testadmin"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "testadmin", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный логин или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Register duplicate login",
      "method": "POST",
      "path": "/?action=register",
      "body": {"login": "testadmin", "password": "secret12345x"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Такой логин уже занят"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "Нет токена"},
      "bodyMatcher": "partial"
    }
  ]
}