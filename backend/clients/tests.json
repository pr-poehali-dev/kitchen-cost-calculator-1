{
  "tests": [
    {
      "name": "List without token returns 401",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "List with pagination returns meta fields",
